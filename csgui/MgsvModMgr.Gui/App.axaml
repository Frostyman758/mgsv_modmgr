<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MgsvModMgr.Gui.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://modmgr_gui/Theme.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <!-- Localised UI strings are merged in at runtime by
                 Lang/LocaleRegistry.Apply() during startup, against
                 whatever locale is saved in state.txt. The strings
                 file ships under Lang/Strings.<code>.axaml — drop a
                 new one in to add a language; the registry discovers
                 it automatically. -->

            <!-- Per-variant brush palette. The Bg / Panel / Border / Text
                 family swaps based on App.RequestedThemeVariant. The
                 red+amber accent palette intentionally stays the same
                 across both themes — that's the mod-manager's brand
                 identity, not a chrome detail. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="Bg"           Color="#131316" />
                    <SolidColorBrush x:Key="Panel"        Color="#131316" />
                    <SolidColorBrush x:Key="PanelAlt"     Color="#1A1A1E" />
                    <SolidColorBrush x:Key="Border"       Color="#26262B" />
                    <SolidColorBrush x:Key="Text"         Color="#E8E8EA" />
                    <SolidColorBrush x:Key="TextDim"      Color="#7C7C84" />
                    <SolidColorBrush x:Key="RowSelect"    Color="#26262C" />
                    <SolidColorBrush x:Key="RowSelectHov" Color="#2E2E34" />
                    <SolidColorBrush x:Key="HeaderHover"  Color="#1F1F23" />
                    <!-- Chrome accents that previously hardcoded dark
                         hex literals: toolbar-active button bg, Nexus
                         card hover bg, tag-chip bg + border. -->
                    <SolidColorBrush x:Key="ToolbarActiveBg" Color="#1E1F25" />
                    <SolidColorBrush x:Key="CardHoverBg"     Color="#1F1F25" />
                    <SolidColorBrush x:Key="ChipBg"          Color="#23232A" />
                    <SolidColorBrush x:Key="ChipBorder"      Color="#3A3A45" />
                    <SolidColorBrush x:Key="GhostPressedBg"  Color="#0F0F12" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <!-- Bg (page header strip / sidebar / footer): the
                         calmer grey the user sees on the "Installed
                         mods" strip. Panel (data area / cards): a soft
                         off-white — not pure #FFFFFF, which read as
                         glaring against the rest. PanelAlt for hover
                         and table-header tints sits between them. -->
                    <SolidColorBrush x:Key="Bg"           Color="#EBEBEF" />
                    <SolidColorBrush x:Key="Panel"        Color="#F8F8FA" />
                    <SolidColorBrush x:Key="PanelAlt"     Color="#E0E0E5" />
                    <SolidColorBrush x:Key="Border"       Color="#D2D2D7" />
                    <SolidColorBrush x:Key="Text"         Color="#1A1A1F" />
                    <SolidColorBrush x:Key="TextDim"      Color="#6C6C72" />
                    <!-- Row selection + header hover paint as a sit-just-
                         above-panel grey in light, so the highlight feels
                         like a subtle "this row is current" instead of a
                         dark slab. Dark theme keeps its existing values. -->
                    <SolidColorBrush x:Key="RowSelect"    Color="#DEDEE4" />
                    <SolidColorBrush x:Key="RowSelectHov" Color="#D3D3DA" />
                    <SolidColorBrush x:Key="HeaderHover"  Color="#DCDCE2" />
                    <!-- Same accents as the Dark variant, paletted for
                         light. Active filter pill = subtle elevated
                         grey; card hover = slightly darker than panel
                         so the hover is felt without being heavy;
                         chip = pill that sits clearly above the card
                         background without going jet-black. -->
                    <SolidColorBrush x:Key="ToolbarActiveBg" Color="#DCDCE3" />
                    <SolidColorBrush x:Key="CardHoverBg"     Color="#EAEAEF" />
                    <SolidColorBrush x:Key="ChipBg"          Color="#E5E5EA" />
                    <SolidColorBrush x:Key="ChipBorder"      Color="#C5C5CB" />
                    <!-- Ghost button pressed: visibly darker than the
                         hover state (PanelAlt) but stays in the light
                         palette. Was painted #0F0F12 which is jet-dark
                         and looked wrong against light chrome. -->
                    <SolidColorBrush x:Key="GhostPressedBg"  Color="#C0C0C7" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Theme-invariant palette. Accent red + amber stay the same
                 in both themes; they're the install-state language. -->
            <Color x:Key="AccentColor">#B62A2A</Color>
            <Color x:Key="AccentDimColor">#5A1414</Color>
            <Color x:Key="DirtyColor">#B89030</Color>
            <Color x:Key="DirtyHoverColor">#D4A848</Color>
            <Color x:Key="DirtyDimColor">#8E6520</Color>

            <SolidColorBrush x:Key="Accent"    Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentDim" Color="{StaticResource AccentDimColor}" />

            <!-- Live "dirty" brush. Its Color is rewritten in code-behind on
                 every DirtyMix change (Add mod, Apply progress, etc.).
                 Anything that should react LIVE to install progress binds
                 against {DynamicResource DirtyBrush}; mutating the brush's
                 Color property propagates to every visual consumer instantly,
                 so the install bar, toggles, primary button, etc. all shift
                 in lockstep. -->
            <SolidColorBrush x:Key="DirtyBrush"     Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="DirtyBrushDim"  Color="{StaticResource AccentDimColor}" />

            <!-- DataGrid cell focus / current-cell border. The Fluent theme
                 paints two separate rectangles (FocusVisual + CurrentBorder)
                 around the currently-focused cell. Override the brushes
                 themselves to transparent so neither can render — selector-
                 level overrides only hit one of them. -->
            <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush"   Color="Transparent" />
            <SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush" Color="Transparent" />
            <SolidColorBrush x:Key="DataGridCellCurrentBorderBrush"        Color="Transparent" />
            <SolidColorBrush x:Key="DataGridCellInvalidBrush"              Color="Transparent" />

            <!-- Override Fluent's accent so any control that falls back to the
                 system accent (selection highlight, toggle on-state, default
                 button pressed/hover, focus rings) renders in our red rather
                 than the default Windows violet. -->
            <Color x:Key="SystemAccentColor">#B62A2A</Color>
            <Color x:Key="SystemAccentColorLight1">#C8413F</Color>
            <Color x:Key="SystemAccentColorLight2">#D75551</Color>
            <Color x:Key="SystemAccentColorLight3">#E4716C</Color>
            <Color x:Key="SystemAccentColorDark1">#971D1D</Color>
            <Color x:Key="SystemAccentColorDark2">#751313</Color>
            <Color x:Key="SystemAccentColorDark3">#5A0F0F</Color>

            <!-- Icon font: bundled Fluent UI System Icons (MIT). Shipped
                 inside the binary so toolbar / sidebar / context-menu
                 glyphs render identically on Windows, Linux, and macOS.
                 All codepoints in the codebase target this font's
                 Unicode range — *not* Segoe Fluent Icons (different
                 codepoints), which is why there's no system-font
                 fallback chain here. -->
            <FontFamily x:Key="IconFont">avares://modmgr_gui/Assets/Fonts/FluentSystemIcons-Resizable.ttf#FluentSystemIcons-Resizable</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
