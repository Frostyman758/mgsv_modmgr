<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MgsvModMgr.Gui.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://modmgr_gui/Theme.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <!-- Palette: MGSV / Phantom Pain — single mid-grey for app+widget bg,
                 blood-red accent, amber for "needs apply" state. -->
            <Color  x:Key="BgColor">#131316</Color>
            <Color  x:Key="PanelColor">#131316</Color>
            <Color  x:Key="PanelAltColor">#1A1A1E</Color>
            <Color  x:Key="BorderColor">#26262B</Color>
            <Color  x:Key="TextColor">#E8E8EA</Color>
            <Color  x:Key="TextDimColor">#7C7C84</Color>
            <Color  x:Key="AccentColor">#B62A2A</Color>
            <Color  x:Key="AccentDimColor">#5A1414</Color>
            <!-- Amber family used while IsDirty=true. Mirrors PENDING APPLY chip. -->
            <Color  x:Key="DirtyColor">#B89030</Color>
            <Color  x:Key="DirtyHoverColor">#D4A848</Color>
            <Color  x:Key="DirtyDimColor">#8E6520</Color>

            <SolidColorBrush x:Key="Bg"        Color="{StaticResource BgColor}" />
            <SolidColorBrush x:Key="Panel"     Color="{StaticResource PanelColor}" />
            <SolidColorBrush x:Key="PanelAlt"  Color="{StaticResource PanelAltColor}" />
            <SolidColorBrush x:Key="Border"    Color="{StaticResource BorderColor}" />
            <SolidColorBrush x:Key="Text"      Color="{StaticResource TextColor}" />
            <SolidColorBrush x:Key="TextDim"   Color="{StaticResource TextDimColor}" />
            <SolidColorBrush x:Key="Accent"    Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentDim" Color="{StaticResource AccentDimColor}" />

            <!-- Live "dirty" brush. Its Color is rewritten in code-behind on
                 every DirtyMix change (Add mod, Apply progress, etc.).
                 Anything that should react LIVE to install progress binds
                 against {DynamicResource DirtyBrush}; mutating the brush's
                 Color property propagates to every visual consumer instantly,
                 so the install bar, toggles, primary button, etc. all shift
                 in lockstep. -->
            <SolidColorBrush x:Key="DirtyBrush"     Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="DirtyBrushDim"  Color="{StaticResource AccentDimColor}" />

            <!-- DataGrid cell focus / current-cell border. The Fluent theme
                 paints two separate rectangles (FocusVisual + CurrentBorder)
                 around the currently-focused cell. Override the brushes
                 themselves to transparent so neither can render — selector-
                 level overrides only hit one of them. -->
            <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush"   Color="Transparent" />
            <SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush" Color="Transparent" />
            <SolidColorBrush x:Key="DataGridCellCurrentBorderBrush"        Color="Transparent" />
            <SolidColorBrush x:Key="DataGridCellInvalidBrush"              Color="Transparent" />

            <!-- Override Fluent's accent so any control that falls back to the
                 system accent (selection highlight, toggle on-state, default
                 button pressed/hover, focus rings) renders in our red rather
                 than the default Windows violet. -->
            <Color x:Key="SystemAccentColor">#B62A2A</Color>
            <Color x:Key="SystemAccentColorLight1">#C8413F</Color>
            <Color x:Key="SystemAccentColorLight2">#D75551</Color>
            <Color x:Key="SystemAccentColorLight3">#E4716C</Color>
            <Color x:Key="SystemAccentColorDark1">#971D1D</Color>
            <Color x:Key="SystemAccentColorDark2">#751313</Color>
            <Color x:Key="SystemAccentColorDark3">#5A0F0F</Color>

            <!-- Icon font: bundled Fluent UI System Icons (MIT). Shipped
                 inside the binary so toolbar / sidebar / context-menu
                 glyphs render identically on Windows, Linux, and macOS.
                 All codepoints in the codebase target this font's
                 Unicode range — *not* Segoe Fluent Icons (different
                 codepoints), which is why there's no system-font
                 fallback chain here. -->
            <FontFamily x:Key="IconFont">avares://modmgr_gui/Assets/Fonts/FluentSystemIcons-Resizable.ttf#FluentSystemIcons-Resizable</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
