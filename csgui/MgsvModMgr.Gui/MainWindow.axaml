<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MgsvModMgr.Gui"
        xmlns:ctl="using:MgsvModMgr.Gui.Controls"
        x:Class="MgsvModMgr.Gui.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        Title="{DynamicResource Str.App.Title}"
        Icon="avares://modmgr_gui/Assets/app.ico"
        Width="980" Height="600"
        MinWidth="980" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        DragDrop.AllowDrop="True"
        Background="{DynamicResource Bg}">

  <!-- Composition root.
       Each major UI surface lives in its own UserControl under
       Controls/. This file is purely structural: page-switching grid +
       overlays + the chrome at top/bottom.

       Two-mode window chrome:
       - WINDOWS: ExtendClientAreaToDecorationsHint=true + NoChrome
         hint (set in attributes above). The OS keeps providing edge
         resize, snap-to-edge, and Win-arrow gestures while we paint
         over the client area.
       - LINUX/macOS: many WMs (notably KWin) ignore the ExtendClientArea
         hint and draw their own title bar regardless. The constructor
         flips to SystemDecorations=None on those platforms and reveals
         the manual ResizeGripsOverlay so edge resize still works.

       Page visibility:
       - All four page surfaces (Mods header + list, Nexus header +
         browser, Settings header + view, Log view) sit at Grid.Row=0/1
         simultaneously. Each uses Classes.active="{Binding IsXxxPage}"
         which the page-class selector in Theme.axaml resolves to
         IsVisible=true / opacity 1.0, so only the active page paints. -->
  <Grid> <!-- outer z-order container: main content + grips overlay -->

    <Grid RowDefinitions="36,*">

      <!-- Custom title bar (row 0): app icon + name + min/max/close. -->
      <ctl:TitleBar Grid.Row="0" x:Name="TitleBarHost"/>

      <Grid Grid.Row="1" ColumnDefinitions="64,*" Classes.dirty="{Binding IsDirty}">

        <!-- Icon nav rail (col 0). -->
        <ctl:SideBar Grid.Column="0"/>

        <!-- Main content area (col 1).
             Row 0 = page header strips (stacked, only the active one
             paints). Row 1 = page bodies (stacked the same way).
             Row 3 = footer status strip. -->
        <Grid Grid.Column="1" RowDefinitions="auto,*,auto,auto">

          <!-- ─── Page headers (Row 0) ─── -->
          <!-- The header UserControls are wrapped in a Border carrying
               the .page class. The Border.page / .page.active style in
               Theme.axaml gates Opacity + IsHitTestVisible so only the
               active page's header paints. (Putting the class directly
               on the UserControl was a dead-end: the existing style
               selector targets Border specifically, not UserControl.) -->
          <Border Grid.Row="0" Classes="page" Classes.active="{Binding IsModsPage}">
            <ctl:ModsHeader x:Name="ModsHeaderHost"/>
          </Border>
          <Border Grid.Row="0" Classes="page" Classes.active="{Binding IsNexusPage}">
            <ctl:NexusHeader/>
          </Border>
          <Border Grid.Row="0" Padding="24,18,24,14" Background="{DynamicResource Bg}"
                  Classes="page"
                  Classes.active="{Binding IsSettingsPage}">
            <StackPanel Spacing="2">
              <TextBlock Text="{DynamicResource Str.Settings.Title}" FontSize="22" FontWeight="SemiBold"/>
              <TextBlock Text="{DynamicResource Str.Settings.Subtitle}"
                         Foreground="{DynamicResource TextDim}" FontSize="12"/>
            </StackPanel>
          </Border>

          <!-- ─── Page bodies (Row 1) ─── -->
          <Border Grid.Row="1" Margin="0,4,0,0"
                  Background="{DynamicResource Panel}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                  ClipToBounds="True"
                  Classes="page"
                  Classes.active="{Binding IsModsPage}">
            <ctl:ModsList x:Name="ModsListHost"/>
          </Border>

          <Border Grid.Row="1" Margin="0,4,0,0"
                  Background="{DynamicResource Panel}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                  Classes="page"
                  Classes.active="{Binding IsNexusPage}">
            <ctl:NexusBrowser/>
          </Border>

          <Border Grid.Row="1" Margin="0,4,0,0"
                  Background="{DynamicResource Panel}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                  Classes="page"
                  Classes.active="{Binding IsSettingsPage}">
            <ctl:SettingsView/>
          </Border>

          <!-- Log page spans the header AND content rows; the page
               has its own internal section headers so it doesn't need
               the title strip. -->
          <Border Grid.Row="0" Grid.RowSpan="2"
                  Background="{DynamicResource Panel}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="0"
                  Classes="page"
                  Classes.active="{Binding IsLogPage}">
            <ctl:LogView/>
          </Border>

          <!-- Row 2 unused (the old log expander lived here). -->

          <!-- Footer (Row 3): live status strip with Apply progress. -->
          <ctl:Footer Grid.Row="3"/>
        </Grid>
      </Grid>

      <!-- Drag overlay: floats above the main content area so it can
           render the ghost row outside any one cell's clip region.
           Spans both columns so the ghost can travel freely across
           the sidebar boundary. Goes LAST so it z-orders on top. -->
      <ctl:DragOverlay Grid.Row="1" x:Name="DragOverlayHost"/>
    </Grid>

    <!-- Resize grip overlay. Hidden by default; the constructor reveals
         it on non-Windows platforms where SystemDecorations=None takes
         away the OS edge-resize hit-zones. Lives at the outer z-order
         layer so it sits above the title bar / sidebar / content. -->
    <ctl:ResizeGripsOverlay x:Name="ResizeGripsHost"/>

  </Grid> <!-- end z-order container -->
</Window>
