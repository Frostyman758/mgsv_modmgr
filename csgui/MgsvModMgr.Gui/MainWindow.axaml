<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MgsvModMgr.Gui"
        xmlns:cmd="using:MgsvModMgr.Gui.Commands"
        xmlns:conv="using:MgsvModMgr.Gui.Converters"
        x:Class="MgsvModMgr.Gui.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        Title="MGSV Mod Manager"
        Icon="avares://modmgr_gui/Assets/app.ico"
        Width="1180" Height="780"
        MinWidth="980" MinHeight="600"
        DragDrop.AllowDrop="True"
        Background="{DynamicResource Bg}">

  <Grid ColumnDefinitions="64,*" Classes.dirty="{Binding IsDirty}">

    <!-- ===================== SIDEBAR ===================== -->
    <!-- Background uses Bg (not Panel) so the sidebar tracks the page-
         header strip's tone in light theme — keeps "chrome" surfaces
         (sidebar / header / footer) one shade, and "content" surfaces
         (data area / cards) the off-white. In dark, Bg == Panel so
         visually identical to before. -->
    <Border Grid.Column="0" Background="{DynamicResource Bg}"
            BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0"
            BoxShadow="4 0 14 0 #00000060">
      <DockPanel LastChildFill="False">

        <!-- Fluent UI System Icons glyphs (bundled font, MIT). Codepoints:
             EB09 = Library (Mods),  E45B = Checkmark (Apply),
             E1A2 = ArrowUndo,       F582 = WindowConsole (Log),
             E7B0 = DocumentText,    E974 = Globe (Nexus),
             EFD2 = Settings,        EA5B = Info -->
        <!-- Top stack:
             - Mods (library) and Nexus (globe) are always visible — those
               are the two top-level views the user moves between.
             - Apply / Revert / Log / DictExport only make sense in the
               install context; they live inside a Border.sidebar-collapse
               that animates MaxHeight + Opacity down to zero while the
               user is on the Nexus page, then slides back when they
               click Mods. ClipToBounds keeps the slide tidy. -->
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,16,0,0"
                    HorizontalAlignment="Center">
          <Button Classes="sidebar" Classes.active="{Binding IsModsPage}"
                  ToolTip.Tip="Installed mods"
                  Content="&#xEB09;"
                  Command="{Binding ShowModsCommand}"/>

          <Border Classes="sidebar-collapse"
                  Classes.collapsed="{Binding IsAwayFromInstallList}">
            <StackPanel Spacing="6" HorizontalAlignment="Center">
              <Button Classes="sidebar" Classes.dirty="{Binding IsDirty}"
                      ToolTip.Tip="Apply pending changes to the game install"
                      Content="&#xE45B;"
                      IsEnabled="{Binding !IsApplying}"
                      Command="{Binding ApplyCommand}"/>
              <Button Classes="sidebar"
                      ToolTip.Tip="Restore the original game files; undo every mod change in the install"
                      Content="&#xE1A2;"
                      IsEnabled="{Binding !IsApplying}"
                      Command="{Binding RevertCommand}"/>
              <Button Classes="sidebar" Classes.active="{Binding IsLogPage}"
                      ToolTip.Tip="Activity log from the last Apply"
                      Content="&#xF582;"
                      Command="{Binding ToggleLogCommand}"/>
              <Button Classes="sidebar"
                      ToolTip.Tip="Rebuild PathDictionary.txt and ExplicitPathDictionary.txt against every installed mod"
                      Content="&#xE7B0;"
                      IsEnabled="{Binding !IsApplying}"
                      Command="{Binding ExportDictCommand}"/>
            </StackPanel>
          </Border>

          <!-- Nexus Mods browser (globe glyph) — always visible. -->
          <Button Classes="sidebar" Classes.active="{Binding IsNexusPage}"
                  ToolTip.Tip="Browse Nexus Mods"
                  Content="&#xE974;"
                  Command="{Binding ShowNexusCommand}"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="0,0,0,16"
                    HorizontalAlignment="Center">
          <Button Classes="sidebar" Classes.active="{Binding IsSettingsPage}"
                  ToolTip.Tip="Game root, datfpk path"
                  Content="&#xEFD2;"
                  Command="{Binding ShowSettingsCommand}"/>
          <Button Classes="sidebar"
                  ToolTip.Tip="About this manager"
                  Content="&#xEA5B;"
                  Command="{Binding AboutCommand}"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ===================== MAIN ===================== -->
    <Grid Grid.Column="1" RowDefinitions="auto,*,auto,auto">

      <!-- ─── Mods page header ─── -->
      <!-- Right-click anywhere in the blank space of this header (i.e.
           outside the title text and the toolbar buttons) → pops the
           column-visibility menu. Wired in code-behind. -->
      <Border x:Name="ModsHeader" Grid.Row="0" Padding="24,18,24,14"
              Background="{DynamicResource Bg}"
              Classes="page"
              Classes.active="{Binding IsModsPage}">
        <Grid ColumnDefinitions="*,auto">
          <StackPanel Grid.Column="0" Spacing="2">
            <TextBlock Text="Installed mods" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding HeaderSubtitle}" Foreground="{DynamicResource TextDim}" FontSize="12"/>
          </StackPanel>
          <!-- Negative right margin shifts the toolbar 4px past the
               page's right padding so the Add button's right edge
               lands on the same X as the ENABLED-column toggle's
               right edge. Tuned to lay between the user's blue
               alignment guides. Use F12 (DevTools) to live-adjust. -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center" Margin="0,0,-4,0">
            <Button Classes="ghost icon"   Content="&#xE48B;"
                    ToolTip.Tip="Move selected mod up in load order"
                    IsEnabled="{Binding !IsApplying}"
                    Command="{Binding MoveUpCommand}"/>
            <Button Classes="ghost icon"   Content="&#xE483;"
                    ToolTip.Tip="Move selected mod down in load order"
                    IsEnabled="{Binding !IsApplying}"
                    Command="{Binding MoveDownCommand}"/>
            <!-- Search pill: 40×40 button matching the trash button's
                 danger palette (DirtyBrush border + glyph, transparent
                 bg). Click → expands leftward via a Width transition
                 into a full search bar; LostFocus with empty text →
                 collapses back. The `.expanded` class toggles via
                 code-behind, driving the icon backplate red and the
                 glyph to white. -->
            <Border x:Name="SearchPill"
                    Background="Transparent"
                    BorderBrush="{DynamicResource DirtyBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="40" Height="40"
                    Cursor="Hand"
                    ClipToBounds="True"
                    PointerPressed="SearchPill_PointerPressed">
              <Border.Transitions>
                <Transitions>
                  <DoubleTransition Property="Width" Duration="0:0:0.22"
                                    Easing="QuadraticEaseOut"/>
                </Transitions>
              </Border.Transitions>
              <Grid ColumnDefinitions="40,*">
                <!-- Magnifier glyph + a backplate Border whose
                     Background flips red ↔ transparent when the pill
                     expands/collapses, signalling the active state.
                     The BrushTransition makes that flip smooth. -->
                <Border Grid.Column="0" x:Name="SearchIconBg"
                        Background="Transparent">
                  <Border.Transitions>
                    <Transitions>
                      <BrushTransition Property="Background" Duration="0:0:0.22"/>
                    </Transitions>
                  </Border.Transitions>
                  <TextBlock x:Name="SearchIconGlyph"
                             Text="&#xEF9A;"
                             FontFamily="{DynamicResource IconFont}"
                             FontSize="16"
                             Foreground="{DynamicResource DirtyBrush}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                </Border>
                <!-- Search textbox. Watermark text + caret white;
                     control's own border/background neutralised across
                     all states so only the outer pill's focus ring
                     shows through. Watermark brush overridden via
                     local resources (Avalonia Fluent paints it from
                     TextControlPlaceholderForeground*). -->
                <TextBox Grid.Column="1" x:Name="SearchBox"
                         Classes="search-pill"
                         IsVisible="False"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         Padding="0,0,12,0"
                         FontSize="13"
                         Watermark="Search list"
                         Foreground="{DynamicResource Text}"
                         CaretBrush="{DynamicResource Text}"
                         Text="{Binding SearchText, Mode=TwoWay}"
                         TextChanged="SearchBox_TextChanged"
                         LostFocus="SearchBox_LostFocus"
                         KeyDown="SearchBox_KeyDown"/>
              </Grid>
            </Border>
            <Button Classes="danger icon"  Content="&#xE666;"
                    ToolTip.Tip="Remove selected mod (run Apply afterwards to rebuild without it)"
                    IsEnabled="{Binding !IsApplying}"
                    Command="{Binding RemoveCommand}"/>
            <Button Classes="primary icon" Content="&#xE00C;"
                    ToolTip.Tip="Add a .mgsv mod archive"
                    IsEnabled="{Binding !IsApplying}"
                    Command="{Binding AddCommand}"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ─── Nexus browser header ─── -->
      <!-- Same shape as the Mods header: title + subtitle on the left,
           a horizontal toolbar of action buttons on the right. The
           filter buttons (Trending / Latest added / Latest updated)
           highlight via Classes.active when their mode is current. -->
      <Border Grid.Row="0" Padding="24,18,24,14" Background="{DynamicResource Bg}"
              Classes="page"
              Classes.active="{Binding IsNexusPage}">
        <Grid ColumnDefinitions="*,auto">
          <StackPanel Grid.Column="0" Spacing="2">
            <TextBlock Text="Nexus Mods" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Browse, search, and install mods from nexusmods.com"
                       Foreground="{DynamicResource TextDim}" FontSize="12"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center" Margin="0,0,-4,0">
            <!-- Always-expanded inline search box. Filters the currently
                 loaded mod set (trending / latest / updated) by Name /
                 Author / Summary substring. Full-catalogue text search
                 needs the GraphQL endpoint — not wired yet. -->
            <Border Width="220" Height="40"
                    Background="Transparent"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="1"
                    CornerRadius="8">
              <Grid ColumnDefinitions="36,*">
                <TextBlock Grid.Column="0" Text="&#xEF9A;"
                           FontFamily="{DynamicResource IconFont}"
                           FontSize="15"
                           Foreground="{DynamicResource TextDim}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Classes="search-pill"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         Padding="0,0,12,0"
                         FontSize="13"
                         Watermark="Search loaded mods"
                         Foreground="{DynamicResource Text}"
                         CaretBrush="{DynamicResource Text}"
                         Text="{Binding NexusSearchText, Mode=TwoWay}"/>
              </Grid>
            </Border>
            <Button Classes="ghost icon" Content="&#xE178;"
                    Classes.active="{Binding IsTrendingFilter}"
                    ToolTip.Tip="Trending"
                    IsEnabled="{Binding !IsNexusLoading}"
                    Command="{Binding SetTrendingFilterCommand}"/>
            <Button Classes="ghost icon" Content="&#xEC73;"
                    Classes.active="{Binding IsLatestAddedFilter}"
                    ToolTip.Tip="Latest added"
                    IsEnabled="{Binding !IsNexusLoading}"
                    Command="{Binding SetLatestAddedFilterCommand}"/>
            <Button Classes="ghost icon" Content="&#xE347;"
                    Classes.active="{Binding IsLatestUpdatedFilter}"
                    ToolTip.Tip="Latest updated"
                    IsEnabled="{Binding !IsNexusLoading}"
                    Command="{Binding SetLatestUpdatedFilterCommand}"/>
            <Button Classes="ghost icon" Content="&#xE0BC;"
                    ToolTip.Tip="Refresh"
                    IsEnabled="{Binding !IsNexusLoading}"
                    Command="{Binding RefreshNexusCommand}"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ─── Settings page header ─── -->
      <Border Grid.Row="0" Padding="24,18,24,14" Background="{DynamicResource Bg}"
              Classes="page"
              Classes.active="{Binding IsSettingsPage}">
        <StackPanel Spacing="2">
          <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold"/>
          <TextBlock Text="Tell the manager where MGSV:TPP and datfpk.exe live."
                     Foreground="{DynamicResource TextDim}" FontSize="12"/>
        </StackPanel>
      </Border>

      <!-- ─── Mods page content (DataGrid) ─── -->
      <Border Grid.Row="1" Margin="0,4,0,0"
              Background="{DynamicResource Panel}"
              BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
              ClipToBounds="True"
              Classes="page"
              Classes.active="{Binding IsModsPage}">
        <DataGrid x:Name="ModListGrid"
                  ItemsSource="{Binding Mods}"
                  SelectedItem="{Binding SelectedMod, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  Background="{DynamicResource Panel}"
                  BorderThickness="0"
                  RowBackground="{DynamicResource Panel}"
                  RowHeight="60">

          <DataGrid.Columns>

            <!-- NAME: mod name + author stacked. The subtitle prefers
                 the author so users see who made each mod; it falls
                 back to the file-name only when metadata.xml didn't
                 include an author. Marked essential (cannot be hidden
                 via the header context menu). -->
            <DataGridTemplateColumn Header="NAME" Width="3*" MinWidth="260">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ModRow">
                  <StackPanel Spacing="2" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource TextDim}" FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- TAGS: user-defined free-form labels, rendered as small chips.
                 Persisted per mod in state.txt. Editing UI comes in a later
                 pass; for now this just surfaces what the data already has. -->
            <DataGridTemplateColumn Header="TAGS" Width="170" MinWidth="120">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ModRow">
                  <ItemsControl ItemsSource="{Binding Tags}"
                                VerticalAlignment="Center" Margin="6,0">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemSpacing="4" LineSpacing="4"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="chip-tag">
                          <TextBlock Text="{Binding}"/>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTextColumn Header="VERSION" Binding="{Binding Version}" Width="90"  MinWidth="60"/>
            <!-- (Former AUTHOR column removed: the author now lives
                 directly under the mod name in the NAME column.) -->

            <!-- QAR / GAMEDIR right-aligned -->
            <DataGridTemplateColumn Header="QAR" Width="80" MinWidth="60">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ModRow">
                  <TextBlock Text="{Binding QarCount}" Foreground="{DynamicResource TextDim}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"
                             Margin="0,0,12,0"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="GAMEDIR" Width="90" MinWidth="60">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ModRow">
                  <TextBlock Text="{Binding GameDirCount}" Foreground="{DynamicResource TextDim}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"
                             Margin="0,0,12,0"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- ENABLED column placed LAST so the toggle column lives on
                 the right edge of the table, directly under the Add-mod
                 button in the toolbar above. Toggle pill is locked to
                 Width=40 to match the Add button's footprint exactly,
                 and the right margin is set so the toggle's right edge
                 lands on the same X as the Add button's right edge
                 (accounting for the DataGrid scrollbar gutter, which
                 eats space on the column's right). -->
            <DataGridTemplateColumn Header="ENABLED" Width="100" CanUserResize="False">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:ModRow">
                  <ToggleSwitch Classes.pending="{Binding IsPending}"
                                IsChecked="{Binding Enabled, Mode=TwoWay}"
                                Width="40"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,15,0"
                                IsEnabled="{Binding !((vm:MainViewModel)DataContext).IsApplying, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

          </DataGrid.Columns>

          <DataGrid.ContextMenu>
            <ContextMenu x:CompileBindings="False">
              <MenuItem Header="Toggle enabled"
                        Command="{Binding ToggleRowCommand}"
                        CommandParameter="{Binding SelectedMod}"/>
              <Separator/>
              <!-- Move up / down: matching glyphs to the toolbar's ghost
                   icon buttons so the context menu reads as the same
                   action as the toolbar entries. -->
              <MenuItem Header="Move up" Command="{Binding MoveUpCommand}">
                <MenuItem.Icon>
                  <TextBlock Text="&#xE48B;"
                             FontFamily="{DynamicResource IconFont}"
                             FontSize="13"/>
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem Header="Move down" Command="{Binding MoveDownCommand}">
                <MenuItem.Icon>
                  <TextBlock Text="&#xE483;"
                             FontFamily="{DynamicResource IconFont}"
                             FontSize="13"/>
                </MenuItem.Icon>
              </MenuItem>
              <Separator/>
              <!-- Remove: danger-classed so text + trash glyph paint
                   with the live DirtyBrush, matching the toolbar's
                   trash button colour & hover treatment. -->
              <MenuItem Header="Remove..." Classes="danger"
                        Command="{Binding RemoveCommand}">
                <MenuItem.Icon>
                  <TextBlock Text="&#xE666;"
                             FontFamily="{DynamicResource IconFont}"
                             FontSize="13"
                             Foreground="{DynamicResource DirtyBrush}"/>
                </MenuItem.Icon>
              </MenuItem>
            </ContextMenu>
          </DataGrid.ContextMenu>
        </DataGrid>
      </Border>

      <!-- ─── Nexus browser content ─── -->
      <Border Grid.Row="1" Margin="0,4,0,0"
              Background="{DynamicResource Panel}"
              BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
              Classes="page"
              Classes.active="{Binding IsNexusPage}">
        <Grid>
          <!-- Empty state: shown when no API key has been entered yet. -->
          <Border IsVisible="{Binding NexusNeedsApiKey}"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Padding="32,28"
                  MaxWidth="520"
                  Background="{DynamicResource PanelAlt}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  CornerRadius="12">
            <StackPanel Spacing="14" HorizontalAlignment="Center">
              <TextBlock Text="&#xEA7A;"
                         FontFamily="{DynamicResource IconFont}"
                         FontSize="34"
                         Foreground="{DynamicResource DirtyBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Sign in to Nexus Mods"
                         FontSize="18" FontWeight="SemiBold"
                         HorizontalAlignment="Center"/>
              <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextDim}"
                         TextAlignment="Center" FontSize="13" LineHeight="20">
                Browsing the mod catalogue needs a Nexus Mods Personal API key.
                Generate one at nexusmods.com → My Account → API and paste it
                into Settings.
              </TextBlock>
              <Button Classes="primary" Content="Open Settings"
                      HorizontalAlignment="Center" Padding="18,8"
                      Command="{Binding ShowSettingsCommand}"/>
            </StackPanel>
          </Border>

          <!-- Loading state: visible while the trending API call is in
               flight. Centred amber spinner-y text using DirtyBrush. -->
          <StackPanel IsVisible="{Binding IsNexusLoading}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Spacing="12">
            <TextBlock Text="&#xE8B6;"
                       FontFamily="{DynamicResource IconFont}"
                       FontSize="34"
                       Foreground="{DynamicResource DirtyBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Loading trending mods..."
                       Foreground="{DynamicResource TextDim}"
                       HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Error state -->
          <Border IsVisible="{Binding HasNexusError}"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Padding="24,20" MaxWidth="480"
                  Background="{DynamicResource PanelAlt}"
                  BorderBrush="{DynamicResource DirtyBrush}" BorderThickness="1"
                  CornerRadius="10">
            <StackPanel Spacing="10">
              <TextBlock Text="{Binding NexusError}"
                         Foreground="{DynamicResource Text}"
                         TextWrapping="Wrap" TextAlignment="Center"/>
              <Button Classes="ghost" Content="Open Settings"
                      HorizontalAlignment="Center"
                      Command="{Binding ShowSettingsCommand}"/>
            </StackPanel>
          </Border>

          <!-- Card grid: visible once trending has loaded AND no card
               drilled into. WrapPanel is HorizontalAlignment=Center so
               the row of cards stays centred under the page header
               regardless of window width / how many fit per row.
               ScrollChanged fires the VM's LoadMoreNexus when the
               user nears the bottom, driving infinite scroll against
               the GraphQL `mods()` query's offset/count pagination. -->
          <ScrollViewer x:Name="NexusGridScroll"
                        IsVisible="{Binding IsNexusListVisible}"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        Padding="20,16,20,20"
                        ScrollChanged="NexusGridScroll_ScrollChanged">
            <StackPanel HorizontalAlignment="Stretch" Spacing="12">
              <!-- Active facet filter — appears at the top of the grid
                   when the user clicked into "by Author" / a category
                   chip / a tag chip from the detail view. The ✕ chip
                   clears the filter and reloads the full grid. -->
              <Border IsVisible="{Binding HasAnyFacetFilter}"
                      HorizontalAlignment="Center"
                      Background="{DynamicResource PanelAlt}"
                      BorderBrush="{DynamicResource DirtyBrush}"
                      BorderThickness="1" CornerRadius="14"
                      Padding="14,6">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                  <TextBlock Text="Filtering:" Foreground="{DynamicResource TextDim}" FontSize="11"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding FacetFilterDisplay}"
                             Foreground="{DynamicResource Text}"
                             FontWeight="SemiBold" FontSize="12"
                             VerticalAlignment="Center"/>
                  <Button Classes="ghost" Padding="6,2"
                          Content="✕"
                          ToolTip.Tip="Clear filter"
                          Command="{Binding ClearFacetFiltersCommand}"/>
                </StackPanel>
              </Border>

              <ItemsControl ItemsSource="{Binding NexusMods}"
                            HorizontalAlignment="Center">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"
                             ItemSpacing="16" LineSpacing="16"
                             HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:NexusModCard">
                  <Border Classes="nexus-card"
                          Width="260" Height="270"
                          PointerPressed="NexusCard_PointerPressed">
                    <Grid RowDefinitions="120,*">
                      <!-- Thumbnail strip. Placeholder glyph shows
                           while the image is in flight (or on fetch
                           failure); the Image swaps in via INPC once
                           PictureUrl has been downloaded. -->
                      <Border Grid.Row="0" Background="#1F1F23"
                              CornerRadius="10,10,0,0"
                              BorderThickness="0,0,0,1"
                              BorderBrush="{DynamicResource Border}"
                              ClipToBounds="True">
                        <Grid>
                          <TextBlock Text="&#xE974;"
                                     FontFamily="{DynamicResource IconFont}"
                                     FontSize="42"
                                     Opacity="0.25"
                                     Foreground="{DynamicResource Text}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding !HasThumbnail}"/>
                          <Image Source="{Binding Thumbnail}"
                                 Stretch="UniformToFill"
                                 IsVisible="{Binding HasThumbnail}"/>
                        </Grid>
                      </Border>
                      <!-- Card body -->
                      <StackPanel Grid.Row="1" Spacing="6" Margin="14,10,14,12">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                   FontSize="14"
                                   TextTrimming="CharacterEllipsis"/>
                        <Border Classes="chip-tag" HorizontalAlignment="Left"
                                IsVisible="{Binding Category, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                          <TextBlock Text="{Binding Category}"/>
                        </Border>
                        <TextBlock Text="{Binding Summary}"
                                   Foreground="{DynamicResource TextDim}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   MaxHeight="44"
                                   TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

          <!-- Detail view: hero spans the FULL viewport width so the
               cover art doesn't get caged in a narrow column on small
               windows / Steam Deck. Everything below the hero is text
               content, which stays in a centred 940 px column for
               readability. ScrollViewer fills the page cell and keeps
               the scrollbar visible so the user can always see they're
               not at the bottom yet. -->
          <ScrollViewer IsVisible="{Binding IsNexusDetailVisible}"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Visible"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
            <StackPanel Spacing="18">

              <!-- Top action row: Back / Open-on-Nexus.
                   Wrapped in a centred 940 column so it lines up with
                   the text content below — only the hero spans full
                   viewport width. -->
              <Grid ColumnDefinitions="auto,*,auto"
                    MaxWidth="940" HorizontalAlignment="Stretch"
                    Margin="24,18,24,0">
                <Button Grid.Column="0" Classes="ghost" Padding="12,7"
                        Command="{Binding ClearNexusSelectionCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#xE112;"
                               FontFamily="{DynamicResource IconFont}"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Back to browse" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                  <Button Classes="ghost" Padding="14,7"
                          Content="Open on Nexus"
                          Command="{Binding OpenNexusInBrowserCommand}"/>
                  <!-- Install: open the mod's Files tab. User hits
                       "Manual download" on Nexus, then drags the saved
                       archive (rar / zip / 7z / .mgsv) onto the Mods
                       page's + button — our Add flow extracts the
                       .mgsv automatically. Nexus removed the in-page
                       "Mod Manager Download" button for free users so
                       the nxm:// route only fires for Premium accounts
                       (handler is still wired and active if it does). -->
                  <Button Classes="primary" Padding="18,8"
                          Content="Install"
                          ToolTip.Tip="Open the mod's Files tab on Nexus. Click 'Manual download' there, then drop the saved archive onto the Mods page's + button."
                          Command="{Binding OpenNexusFilesPageCommand}"/>
                </StackPanel>
              </Grid>

              <!-- Hero image with a *responsive cap*. MaxWidth=940 with
                   HorizontalAlignment=Stretch is the magic combo:
                   - Wide / fullscreen → hero caps at 940 px and centres
                     in the viewport with gutters (the original look).
                   - Narrow / Steam-Deck → viewport < 940, so the cap
                     stops applying and the hero stretches edge-to-edge.
                   The handoff is continuous: as you drag the window
                   smaller, the hero stays 940 until the viewport hits
                   940, then it tracks the viewport width all the way
                   down. No breakpoints, no animation triggers — just
                   the layout engine doing what it's supposed to. -->
              <Border Background="#1F1F23"
                      BorderBrush="{DynamicResource Border}"
                      BorderThickness="0,1,0,1"
                      MaxWidth="940" HorizontalAlignment="Stretch"
                      MinHeight="180" MaxHeight="320"
                      ClipToBounds="True">
                <Grid>
                  <TextBlock Text="&#xE974;"
                             FontFamily="{DynamicResource IconFont}"
                             FontSize="60" Opacity="0.2"
                             Foreground="{DynamicResource Text}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             IsVisible="{Binding !NexusSelectedMod.HasThumbnail}"/>
                  <Image Source="{Binding NexusSelectedMod.Thumbnail}"
                         Stretch="UniformToFill"
                         IsVisible="{Binding NexusSelectedMod.HasThumbnail}"/>
                </Grid>
              </Border>

              <!-- All non-hero content lives in a centred 940 column with
                   side margins matching the page padding. Wrapper lets
                   the hero break out to full viewport width while text
                   stays readable. -->
              <StackPanel MaxWidth="940" HorizontalAlignment="Stretch"
                          Margin="24,0,24,28" Spacing="18">

              <!-- Title row: name + chip + author on the LEFT, three
                   compact stat tiles on the RIGHT, sharing one horizontal
                   strip. Frees up vertical real-estate so the About card
                   below has room to breathe on short windows. -->
              <Grid ColumnDefinitions="*,auto" ColumnSpacing="20">
                <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Text="{Binding NexusSelectedMod.Name}"
                             FontSize="24" FontWeight="SemiBold"
                             TextWrapping="Wrap"/>
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <!-- Category chip is now a Button so clicking it
                         routes to the browse grid filtered to that
                         category via FilterByCurrentCategoryCommand. -->
                    <Button Classes="chip-button"
                            IsVisible="{Binding NexusSelectedMod.Category, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Command="{Binding FilterByCurrentCategoryCommand}"
                            ToolTip.Tip="Show all mods in this category">
                      <Border Classes="chip-tag">
                        <TextBlock Text="{Binding NexusSelectedMod.Category}"/>
                      </Border>
                    </Button>
                    <!-- "by <author>" — clicking the author name routes
                         to the grid filtered to that author's mods. -->
                    <Button Classes="link-button"
                            Command="{Binding FilterByCurrentAuthorCommand}"
                            ToolTip.Tip="Show all mods by this author">
                      <TextBlock VerticalAlignment="Center">
                        <Run Text="by " Foreground="{DynamicResource TextDim}"/><Run
                              Text="{Binding NexusSelectedMod.Author}"
                              Foreground="{DynamicResource DirtyBrush}"
                              FontWeight="SemiBold"/>
                      </TextBlock>
                    </Button>
                  </StackPanel>
                </StackPanel>

                <!-- Inline 3-tile stat row aligned to the title block. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Spacing="10" VerticalAlignment="Center">
                  <Border Classes="stat-tile" Width="120">
                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding NexusSelectedMod.Downloads, StringFormat='{}{0:N0}'}"
                                 FontSize="16" FontWeight="SemiBold"
                                 HorizontalAlignment="Center"/>
                      <TextBlock Text="Downloads"
                                 Foreground="{DynamicResource TextDim}"
                                 FontSize="10"
                                 HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                  <Border Classes="stat-tile" Width="120">
                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding NexusSelectedMod.Endorsements, StringFormat='{}{0:N0}'}"
                                 FontSize="16" FontWeight="SemiBold"
                                 HorizontalAlignment="Center"/>
                      <TextBlock Text="Endorsements"
                                 Foreground="{DynamicResource TextDim}"
                                 FontSize="10"
                                 HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                  <Border Classes="stat-tile" Width="120">
                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding NexusSelectedMod.Version}"
                                 FontSize="16" FontWeight="SemiBold"
                                 HorizontalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="Version"
                                 Foreground="{DynamicResource TextDim}"
                                 FontSize="10"
                                 HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Grid>

              <!-- About card — short summary, always available from the
                   list query. -->
              <Border Classes="info-card">
                <StackPanel Spacing="10">
                  <TextBlock Text="ABOUT"
                             Foreground="{DynamicResource TextDim}"
                             FontSize="11" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding NexusSelectedMod.Summary}"
                             TextWrapping="Wrap" LineHeight="20"
                             Foreground="{DynamicResource Text}"/>
                </StackPanel>
              </Border>

              <!-- Description card — the full body text from the v2
                   mod() query. Fetched lazily on detail-view open;
                   hidden until DetailsLoaded fires. -->
              <Border Classes="info-card"
                      IsVisible="{Binding NexusSelectedMod.HasFullDescription}">
                <StackPanel Spacing="10">
                  <TextBlock Text="DESCRIPTION"
                             Foreground="{DynamicResource TextDim}"
                             FontSize="11" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding NexusSelectedMod.FullDescription}"
                             TextWrapping="Wrap" LineHeight="20"
                             Foreground="{DynamicResource Text}"/>
                </StackPanel>
              </Border>

              <!-- Requirements card — list of mods this one needs.
                   Each row carries an Open button to jump to the
                   required mod's Nexus page in the browser. -->
              <Border Classes="info-card"
                      IsVisible="{Binding NexusSelectedMod.HasRequirements}">
                <StackPanel Spacing="10">
                  <TextBlock Text="REQUIREMENTS"
                             Foreground="{DynamicResource TextDim}"
                             FontSize="11" FontWeight="SemiBold"/>
                  <ItemsControl ItemsSource="{Binding NexusSelectedMod.Requirements}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Spacing="6"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:NexusRequirementRow">
                        <Border Background="{DynamicResource PanelAlt}"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="12,8">
                          <Grid ColumnDefinitions="*,auto" ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="2">
                              <TextBlock Text="{Binding ModName}"
                                         FontWeight="SemiBold"
                                         TextTrimming="CharacterEllipsis"/>
                              <TextBlock Text="{Binding Notes}"
                                         IsVisible="{Binding HasNotes}"
                                         Foreground="{DynamicResource TextDim}"
                                         FontSize="11"
                                         TextWrapping="Wrap"/>
                            </StackPanel>
                            <Border Grid.Column="1" Classes="chip-tag"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                              <TextBlock Text="{Binding Label}"/>
                            </Border>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <!-- Tag chips — clickable; each filters the grid by that tag. -->
              <Border Classes="info-card"
                      IsVisible="{Binding NexusSelectedMod.Tags.Count}">
                <StackPanel Spacing="10">
                  <TextBlock Text="TAGS"
                             Foreground="{DynamicResource TextDim}"
                             FontSize="11" FontWeight="SemiBold"/>
                  <ItemsControl ItemsSource="{Binding NexusSelectedMod.Tags}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemSpacing="6" LineSpacing="6"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Classes="chip-button"
                                Click="NexusTag_Click"
                                Tag="{Binding}">
                          <Border Classes="chip-tag">
                            <TextBlock Text="{Binding}"/>
                          </Border>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <!-- TODO: Install/Download via nxm:// handler arrives next
                   pass. For now Open-on-Nexus at the top routes the
                   user to the mod page where the "Mod Manager Download"
                   button fires nxm://. -->

              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- ─── Settings page content ─── -->
      <Border Grid.Row="1" Margin="0,4,0,0"
              Background="{DynamicResource Panel}"
              BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
              Classes="page"
              Classes.active="{Binding IsSettingsPage}">
        <ScrollViewer>
          <StackPanel Spacing="24" Margin="28,22,28,22" MaxWidth="720" HorizontalAlignment="Stretch">

            <!-- Game root -->
            <StackPanel Spacing="6">
              <TextBlock Text="GAME ROOT" Foreground="{DynamicResource TextDim}"
                         FontSize="11" FontWeight="SemiBold"/>
              <TextBlock Text="The folder that contains mgsvtpp.exe."
                         Foreground="{DynamicResource TextDim}" FontSize="12"/>
              <Grid ColumnDefinitions="*,auto" Margin="0,4,0,0">
                <TextBox Grid.Column="0" Classes="path"
                         Watermark="C:\Program Files (x86)\Steam\steamapps\common\MGS_TPP"
                         Text="{Binding GameRootField, Mode=TwoWay}"/>
                <Button Grid.Column="1" Classes="ghost" Content="Browse..."
                        Margin="8,0,0,0" Width="100"
                        Command="{Binding BrowseGameRootCommand}"/>
              </Grid>
            </StackPanel>

            <!-- datfpk -->
            <StackPanel Spacing="6">
              <TextBlock Text="DATFPK" Foreground="{DynamicResource TextDim}"
                         FontSize="11" FontWeight="SemiBold"/>
              <TextBlock Text="Path to the datfpk packer/unpacker binary. Required by Apply."
                         Foreground="{DynamicResource TextDim}" FontSize="12"/>
              <Grid ColumnDefinitions="*,auto" Margin="0,4,0,0">
                <TextBox Grid.Column="0" Classes="path"
                         Watermark="C:\tools\datfpk.exe   (or /usr/local/bin/datfpk)"
                         Text="{Binding DatFpkField, Mode=TwoWay}"/>
                <Button Grid.Column="1" Classes="ghost" Content="Browse..."
                        Margin="8,0,0,0" Width="100"
                        Command="{Binding BrowseDatFpkCommand}"/>
              </Grid>
            </StackPanel>

            <!-- Nexus Mods API key. Two paths to populate it:
                 (a) the "Sign in with Nexus" button below, which opens
                     a browser approval page (SSO) and pipes the key
                     back through a WebSocket;
                 (b) paste a Personal API key manually from
                     nexusmods.com → My Account → API.
                 Either way the key needs Save Settings to persist. -->
            <StackPanel Spacing="6">
              <TextBlock Text="NEXUS MODS API KEY" Foreground="{DynamicResource TextDim}"
                         FontSize="11" FontWeight="SemiBold"/>
              <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" FontSize="12">
                Sign in via Nexus to authorise this app and receive an
                API key, or paste a Personal API key manually.
              </TextBlock>
              <Grid ColumnDefinitions="*,auto" Margin="0,4,0,0">
                <TextBox Grid.Column="0" Classes="path"
                         Watermark="paste your Personal API key here"
                         PasswordChar="•"
                         Text="{Binding NexusApiKeyField, Mode=TwoWay}"/>
                <Button Grid.Column="1" Classes="ghost"
                        Margin="8,0,0,0" Padding="14,8"
                        ToolTip.Tip="Open the Nexus approval page in your browser. Once you click Approve there, the API key is filled in for you."
                        Command="{Binding NexusSsoSignInCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#xEA7A;"
                               FontFamily="{DynamicResource IconFont}"
                               FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Sign in with Nexus" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </Grid>
            </StackPanel>

            <!-- Theme preference. Toggle persists in state.txt and is
                 applied live on flip via ApplyThemeVariant. -->
            <StackPanel Spacing="6">
              <TextBlock Text="THEME" Foreground="{DynamicResource TextDim}"
                         FontSize="11" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Light theme" Foreground="{DynamicResource Text}"
                           VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding IsLightTheme, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" FontSize="12">
                Swaps the background / panel / text palette. The
                red/amber install-state colours stay the same.
              </TextBlock>
            </StackPanel>

            <!-- Save / Cancel: sized to match the Browse buttons above so the
                 right edges line up neatly with the form fields. -->
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
              <Button Classes="ghost"   Content="Back"  Width="100"
                      Command="{Binding ShowModsCommand}"/>
              <Button Classes="primary" Content="Save"  Width="100"
                      Command="{Binding SaveSettingsCommand}"/>
            </StackPanel>

            <!-- ─── Maintenance ─────────────────────────────────────────── -->
            <Border BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                    Margin="0,24,0,0" Padding="0,20,0,0">
              <StackPanel Spacing="6">
                <TextBlock Text="MAINTENANCE" Foreground="{DynamicResource TextDim}"
                           FontSize="11" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextDim}" FontSize="12">
                  Clear the Apply cache and per-host scratch directories. The next Apply
                  will rebuild every host from scratch. Does not touch your game install
                  or the mod list.
                </TextBlock>
                <Button Classes="ghost" Content="Reset Apply state"
                        HorizontalAlignment="Left" Margin="0,6,0,0"
                        Command="{Binding ResetApplyStateCommand}"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ─── Log page content (spans the header AND content rows) ─── -->
      <!-- Unlike the other pages, the Log doesn't carry a title +
           subtitle strip — its two section headers (ACTIVITY LOG /
           FILE CONFLICTS) act as their own titles. Spanning Row 0+1
           kills the empty "forehead" that other pages reserve for
           their title block, so the log + conflict list claim the
           full vertical space all the way up to the window chrome. -->
      <Border Grid.Row="0" Grid.RowSpan="2"
              Background="{DynamicResource Panel}"
              BorderBrush="{DynamicResource Border}" BorderThickness="0"
              Classes="page"
              Classes.active="{Binding IsLogPage}">
        <Grid RowDefinitions="*,*">

          <!-- Top half: existing activity log -->
          <DockPanel Grid.Row="0" LastChildFill="True">
            <Border DockPanel.Dock="Top" Background="{DynamicResource PanelAlt}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                    Padding="14,10">
              <Grid ColumnDefinitions="*,auto">
                <TextBlock Grid.Column="0" Text="ACTIVITY LOG"
                           Foreground="{DynamicResource TextDim}"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Classes="ghost" Content="Back to mods"
                        Padding="10,4"
                        Command="{Binding ShowModsCommand}"/>
              </Grid>
            </Border>
            <TextBox Classes="log"
                     BorderThickness="0" CornerRadius="0"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     Text="{Binding LogText}"
                     Name="LogBox"/>
          </DockPanel>

          <!-- Bottom half: file conflicts -->
          <DockPanel Grid.Row="1" LastChildFill="True">
            <Border DockPanel.Dock="Top" Background="{DynamicResource PanelAlt}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,1"
                    Padding="14,10">
              <Grid ColumnDefinitions="*,auto">
                <TextBlock Grid.Column="0" Text="FILE CONFLICTS"
                           Foreground="{DynamicResource TextDim}"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ConflictsCountLabel}"
                           Foreground="{DynamicResource TextDim}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
              </Grid>
            </Border>

            <!-- Empty state: no conflicts (everything is harmonious) -->
            <Border IsVisible="{Binding !HasConflicts}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="20,16">
              <TextBlock Text="No file conflicts detected. The enabled mods don't fight over any files in the current load order."
                         Foreground="{DynamicResource TextDim}"
                         FontStyle="Italic"
                         TextAlignment="Center"
                         TextWrapping="Wrap"
                         MaxWidth="520"/>
            </Border>

            <!-- Conflicts list -->
            <ScrollViewer IsVisible="{Binding HasConflicts}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0">
              <ItemsControl ItemsSource="{Binding Conflicts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ConflictRowVm">
                    <Border BorderBrush="{DynamicResource Border}"
                            BorderThickness="0,0,0,1"
                            Padding="16,10">
                      <Grid ColumnDefinitions="auto,*,auto" ColumnSpacing="12">
                        <!-- Category chip on the left (QAR / GAMEDIR / FPK) -->
                        <Border Grid.Column="0" Classes="chip-tag" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Category}"/>
                        </Border>
                        <!-- Path + winner / loser stack -->
                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Path}"
                                     FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                     FontSize="11"
                                     TextTrimming="CharacterEllipsis"
                                     Foreground="{DynamicResource Text}"/>
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="winner:" Foreground="{DynamicResource TextDim}" FontSize="11"/>
                            <TextBlock Text="{Binding Winner}"
                                       Foreground="{DynamicResource DirtyBrush}"
                                       FontWeight="SemiBold" FontSize="11"/>
                            <TextBlock Text="•" Foreground="{DynamicResource TextDim}" FontSize="11"
                                       Margin="6,0,0,0"/>
                            <TextBlock Text="overridden:" Foreground="{DynamicResource TextDim}" FontSize="11"/>
                            <TextBlock Text="{Binding OverriddenJoined}"
                                       Foreground="{DynamicResource TextDim}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding CountSubtitle}"
                                   Foreground="{DynamicResource TextDim}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Grid>
      </Border>

      <!-- Row 2 unused (the old log expander lived here). -->

      <!-- status footer with thin Apply-progress bar pinned above it.
           Click anywhere on the strip to hide it; auto-shows again
           when the next Apply starts. -->
      <DockPanel Grid.Row="3" LastChildFill="True"
                 IsVisible="{Binding IsFooterShown}">
        <!-- Progress bar: 2px tall. Its fill IS the live DirtyBrush —
             same brush instance the toggles, Add button, sidebar Apply
             pip and trash button paint with. As ApplyProgress moves,
             code-behind rewrites DirtyBrush.Color and every consumer
             repaints in the same frame, perfectly in sync. -->
        <ProgressBar DockPanel.Dock="Top"
                     Height="2" Minimum="0" Maximum="1"
                     Value="{Binding ApplyProgress}"
                     IsVisible="{Binding IsApplying}"
                     Foreground="{DynamicResource DirtyBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     CornerRadius="0"
                     ShowProgressText="False"/>
        <!-- Footer Background uses Bg so the chrome row tracks the
             sidebar + header grey in light theme. -->
        <Border Background="{DynamicResource Bg}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                Padding="24,8"
                Cursor="Hand"
                PointerPressed="Footer_PointerPressed"
                ToolTip.Tip="Click to hide. Reappears automatically while an Apply is running.">
          <StackPanel Orientation="Horizontal" Spacing="20">
            <TextBlock Foreground="{DynamicResource TextDim}" FontSize="11">
              <Run Text="Game root:"/><Run Text=" "/><Run Text="{Binding GameRoot}" Foreground="{DynamicResource Text}"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource TextDim}" FontSize="11">
              <Run Text="datfpk:"/><Run Text=" "/><Run Text="{Binding DatFpk}" Foreground="{DynamicResource Text}"/>
            </TextBlock>
          </StackPanel>
        </Border>
      </DockPanel>
    </Grid>

    <!-- Drag overlay: a transparent canvas pinned above the main content
         that hosts the "lifted" row ghost and the insertion indicator
         line. IsHitTestVisible=False so it never blocks pointer input;
         positions are written in code-behind from PointerMoved while a
         drag is in flight. Spans both columns so the ghost can travel
         freely across the sidebar boundary, and is the LAST root child
         so it z-orders above the DataGrid / sidebar. -->
    <Canvas x:Name="DragOverlay"
            Grid.Column="0" Grid.ColumnSpan="2"
            IsHitTestVisible="False">
      <!-- Lifted row ghost: floats with the cursor while dragging.
           Tinted with the live DirtyBrush so it matches the rest of
           the install-state palette. -->
      <Border x:Name="DragGhost"
              IsVisible="False"
              Background="{DynamicResource PanelAlt}"
              BorderBrush="{DynamicResource DirtyBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="14,8"
              Opacity="0.95"
              BoxShadow="0 8 22 0 #00000080">
        <TextBlock x:Name="DragGhostText"
                   Foreground="{DynamicResource Text}"
                   FontWeight="SemiBold" FontSize="13"/>
      </Border>
      <!-- Insertion indicator: a thin horizontal bar that snaps to the
           gap between two rows, showing exactly where the dragged item
           will land on release. -->
      <Border x:Name="DragInsertLine"
              IsVisible="False"
              Height="3"
              Background="{DynamicResource DirtyBrush}"
              CornerRadius="2"/>
    </Canvas>
  </Grid>
</Window>
