<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window chrome -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource Bg}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize"   Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource Text}" />
    </Style>

    <!-- TextBlock default -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Text}" />
    </Style>

    <!-- Sidebar icon button — monochrome glyph; active state is a subtle
         left accent rail + brighter glyph, no filled bg. Sized to match the
         "+ Add mod" toolbar button (~38 px tall) for visual consistency. -->
    <Style Selector="Button.sidebar">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="{DynamicResource TextDim}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width"  Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets,Segoe UI Symbol,Segoe UI" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment"   Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="Button.sidebar:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Text}" />
    </Style>
    <Style Selector="Button.sidebar.active">
        <Setter Property="Foreground" Value="{DynamicResource Text}" />
    </Style>
    <Style Selector="Button.sidebar.active /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Pulsing amber background while the manager has un-Applied changes.
         The icon itself stays white so it reads cleanly against the pulse.
         Matches the PENDING APPLY chip palette so users learn one rule:
         amber = "needs Apply". Bound via `Classes.dirty="{Binding IsDirty}"`. -->
    <Style Selector="Button.sidebar.dirty">
        <Setter Property="Foreground" Value="{DynamicResource Text}" />
    </Style>
    <Style Selector="Button.sidebar.dirty /template/ ContentPresenter">
        <Style.Animations>
            <Animation Duration="0:0:1.0" IterationCount="INFINITE" PlaybackDirection="Alternate">
                <KeyFrame Cue="0%">
                    <Setter Property="Background" Value="#2B221A" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Background" Value="#8E6520" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Primary (filled red) -->
    <Style Selector="Button.primary">
        <Setter Property="Background"      Value="{DynamicResource Accent}" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="BorderBrush"     Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"         Value="14,8" />
        <Setter Property="CornerRadius"    Value="8" />
        <Setter Property="FontWeight"      Value="SemiBold" />
    </Style>
    <Style Selector="Button.primary /template/ ContentPresenter">
        <Setter Property="Background"  Value="{DynamicResource Accent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background"  Value="#C8413F" />
        <Setter Property="BorderBrush" Value="#C8413F" />
        <Setter Property="TextElement.Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
        <Setter Property="Background"  Value="#8E1F1F" />
        <Setter Property="BorderBrush" Value="#8E1F1F" />
        <Setter Property="TextElement.Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:disabled /template/ ContentPresenter">
        <Setter Property="Background"  Value="#3A1414" />
        <Setter Property="BorderBrush" Value="#3A1414" />
        <Setter Property="TextElement.Foreground" Value="#8C7676" />
    </Style>

    <!-- Ghost (outlined neutral) -->
    <Style Selector="Button.ghost">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="{DynamicResource Text}" />
        <Setter Property="BorderBrush"     Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"         Value="12,7" />
        <Setter Property="CornerRadius"    Value="8" />
    </Style>
    <Style Selector="Button.ghost /template/ ContentPresenter">
        <Setter Property="Background"  Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background"  Value="{DynamicResource PanelAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Text}" />
    </Style>
    <Style Selector="Button.ghost:pressed /template/ ContentPresenter">
        <Setter Property="Background"  Value="#0F0F12" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Text}" />
    </Style>

    <!-- Square icon button (toolbar Up/Down/Add/Remove). Inherits the
         visual personality of the .ghost/.primary/.danger siblings via an
         extra class; this base just sizes them. Height intentionally larger
         than the 16pt glyph so descenders (trash, etc.) aren't clipped. -->
    <Style Selector="Button.icon">
        <Setter Property="Width"          Value="40" />
        <Setter Property="Height"         Value="40" />
        <Setter Property="Padding"        Value="0" />
        <Setter Property="FontFamily"     Value="Segoe Fluent Icons,Segoe MDL2 Assets,Segoe UI Symbol,Segoe UI" />
        <Setter Property="FontSize"       Value="16" />
        <Setter Property="CornerRadius"   Value="8" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>

    <!-- Danger (outlined red text) -->
    <Style Selector="Button.danger">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="#FF6B7A" />
        <Setter Property="BorderBrush"     Value="#3F2A30" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding"         Value="12,7" />
        <Setter Property="CornerRadius"    Value="8" />
    </Style>
    <Style Selector="Button.danger /template/ ContentPresenter">
        <Setter Property="Background"  Value="Transparent" />
        <Setter Property="BorderBrush" Value="#3F2A30" />
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background"  Value="#2E1518" />
        <Setter Property="BorderBrush" Value="#5A1F26" />
        <Setter Property="TextElement.Foreground" Value="#FF8A95" />
    </Style>
    <Style Selector="Button.danger:pressed /template/ ContentPresenter">
        <Setter Property="Background"  Value="#1F0E10" />
        <Setter Property="BorderBrush" Value="#5A1F26" />
        <Setter Property="TextElement.Foreground" Value="#FF6B7A" />
    </Style>

    <!-- "Mod row" border -->
    <Style Selector="Border.row">
        <Setter Property="Background"      Value="{DynamicResource Panel}" />
        <Setter Property="BorderBrush"     Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding"         Value="14,12" />
    </Style>
    <Style Selector="Border.row:pointerover">
        <Setter Property="Background" Value="{DynamicResource PanelAlt}" />
    </Style>
    <Style Selector="Border.row.selected">
        <Setter Property="Background" Value="#231C3D" />
    </Style>

    <!-- ListBox transparent so we draw our own row Border -->
    <Style Selector="ListBox">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding"         Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding"         Value="0" />
        <Setter Property="Background"      Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Single-line path field (Settings page) -->
    <Style Selector="TextBox.path">
        <Setter Property="Background"      Value="{DynamicResource Bg}" />
        <Setter Property="BorderBrush"     Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius"    Value="8" />
        <Setter Property="Padding"         Value="10,8" />
        <Setter Property="Foreground"      Value="{DynamicResource Text}" />
        <Setter Property="FontFamily"      Value="Cascadia Mono,Consolas,Menlo,monospace" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox.path:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>

    <!-- Read-only multiline log -->
    <Style Selector="TextBox.log">
        <Setter Property="Background"      Value="{DynamicResource Panel}" />
        <Setter Property="BorderBrush"     Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius"    Value="8" />
        <Setter Property="Padding"         Value="12,10" />
        <Setter Property="FontFamily"      Value="Cascadia Mono,Consolas,Menlo,monospace" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="Foreground"      Value="{DynamicResource Text}" />
    </Style>

    <!-- ToggleSwitch (smaller, accent-tinted red) -->
    <Style Selector="ToggleSwitch">
        <Setter Property="OnContent"  Value="" />
        <Setter Property="OffContent" Value="" />
        <Setter Property="Padding"    Value="0" />
        <Setter Property="MinWidth"   Value="0" />
    </Style>
    <!-- Track fill (the colored pill behind the thumb) when checked. -->
    <Style Selector="ToggleSwitch:checked /template/ Border#SwitchKnobBounds">
        <Setter Property="Background"  Value="{DynamicResource Accent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>
    <Style Selector="ToggleSwitch:checked:pointerover /template/ Border#SwitchKnobBounds">
        <Setter Property="Background"  Value="#D34646" />
        <Setter Property="BorderBrush" Value="#D34646" />
    </Style>
    <Style Selector="ToggleSwitch:checked:pressed /template/ Border#SwitchKnobBounds">
        <Setter Property="Background"  Value="#8E1F1F" />
        <Setter Property="BorderBrush" Value="#8E1F1F" />
    </Style>
    <!-- Thumb stays white. -->
    <Style Selector="ToggleSwitch:checked /template/ Border#SwitchKnobOn">
        <Setter Property="Background" Value="White" />
    </Style>

    <!-- PENDING chip: rendered on a row whose state hasn't been Applied yet. -->
    <Style Selector="Border.chip-pending">
        <Setter Property="Background"      Value="#2B221A" />
        <Setter Property="BorderBrush"     Value="#5A431F" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius"    Value="10" />
        <Setter Property="Padding"         Value="8,2" />
    </Style>
    <Style Selector="Border.chip-pending TextBlock">
        <Setter Property="Foreground" Value="#E8B85A" />
        <Setter Property="FontSize"   Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Muted (grey) toggle for pending rows: same shape, no accent fill. -->
    <Style Selector="ToggleSwitch.pending:checked /template/ Border#SwitchKnobBounds">
        <Setter Property="Background"  Value="#5A5A62" />
        <Setter Property="BorderBrush" Value="#5A5A62" />
    </Style>
    <Style Selector="ToggleSwitch.pending:checked:pointerover /template/ Border#SwitchKnobBounds">
        <Setter Property="Background"  Value="#6E6E78" />
        <Setter Property="BorderBrush" Value="#6E6E78" />
    </Style>

    <!-- Context menu styling -->
    <Style Selector="MenuItem">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize"   Value="12" />
        <Setter Property="Padding"    Value="12,6" />
    </Style>
    <Style Selector="ContextMenu">
        <Setter Property="Background"      Value="{DynamicResource Panel}" />
        <Setter Property="BorderBrush"     Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius"    Value="8" />
        <Setter Property="Padding"         Value="4" />
    </Style>

</Styles>
